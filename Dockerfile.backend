FROM python:3.12-slim

WORKDIR /app

# Dépendances Python
COPY requirements.txt /app/
RUN pip install --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    -r requirements.txt

# Code backend
COPY backend/ /app/backend/

# Données lues par tools.py (chemins relatifs à la racine du projet)
COPY data/maregraphie/ /app/data/maregraphie/
COPY public/data/      /app/public/data/

WORKDIR /app/backend

EXPOSE 8000
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
